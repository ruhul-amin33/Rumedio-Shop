<div style="padding:8px 0;">
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:12px;">
    <h2 style="margin:0; font-size:1.2rem; font-weight:700; color:#212121; font-family:'Inter',sans-serif; display:flex; align-items:center; gap:8px;">
      <i class="fas fa-users" style="color:#F57224;"></i> Newsletter Subscribers
      <span style="background:#FFF3EC; color:#F57224; font-size:0.72rem; font-weight:700; padding:2px 10px; border-radius:20px; border:1px solid #FED7AA;"><%= subscribers.length %></span>
    </h2>
  </div>
  <div style="background:white; border-radius:10px; border:1px solid #E0E0E0; box-shadow:0 2px 8px rgba(0,0,0,0.06); overflow:hidden;">
    <div style="overflow-x:auto;">
      <table style="width:100%; border-collapse:collapse; font-size:0.85rem;">
        <thead>
          <tr style="background:#1A2A4A; border-bottom:2px solid #F57224;">
            <th style="padding:13px 18px; text-align:center; font-weight:700; color:white; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px;">ID</th>
            <th style="padding:13px 18px; text-align:left; font-weight:700; color:white; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px;">Email</th>
            <th style="padding:13px 18px; text-align:center; font-weight:700; color:white; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px;">Subscribed At</th>
          </tr>
        </thead>
        <tbody>
          <% subscribers.forEach((sub, i) => {
            const dt = new Date(sub.subscribed_at);
            const formatted = dt.toLocaleString('en-GB', { year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit', hour12:false });
          %>
          <tr style="border-bottom:1px solid #F0F0F0; background:<%= i % 2 === 0 ? 'white' : '#FAFAFA' %>;" onmouseover="this.style.background='#FFF3EC'" onmouseout="this.style.background='<%= i % 2 === 0 ? 'white' : '#FAFAFA' %>'">
            <td style="padding:12px 18px; text-align:center; color:#9E9E9E; font-size:0.78rem;">#<%= sub.id %></td>
            <td style="padding:12px 18px; color:#212121; font-weight:500;">
              <a href="mailto:<%= sub.email %>" style="color:#212121; text-decoration:none;" onmouseover="this.style.color='#F57224'" onmouseout="this.style.color='#212121'">
                <i class="fas fa-envelope" style="color:#F57224; margin-right:6px; font-size:0.78rem;"></i><%= sub.email %>
              </a>
            </td>
            <td style="padding:12px 18px; text-align:center; color:#9E9E9E; font-size:0.78rem;"><%= formatted %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
