<div style="padding:8px 0;">
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:12px;">
    <h2 style="margin:0; font-size:1.2rem; font-weight:700; color:#212121; font-family:'Inter',sans-serif; display:flex; align-items:center; gap:8px;">
      <i class="fas fa-boxes" style="color:#F57224;"></i> Manage Products
      <span style="background:#FFF3EC; color:#F57224; font-size:0.72rem; font-weight:700; padding:2px 10px; border-radius:20px; border:1px solid #FED7AA;"><%= products.length %></span>
    </h2>
    <a href="/dashboard/products-add" style="background:#F57224; color:white; padding:8px 18px; border-radius:6px; font-size:0.82rem; font-weight:600; text-decoration:none; display:flex; align-items:center; gap:6px;" onmouseover="this.style.background='#D4601A'" onmouseout="this.style.background='#F57224'">
      <i class="fas fa-plus"></i> Add New
    </a>
  </div>

  <div style="background:white; border-radius:10px; border:1px solid #E0E0E0; box-shadow:0 2px 8px rgba(0,0,0,0.06); overflow:hidden;">
    <div style="overflow-x:auto;">
      <table style="width:100%; border-collapse:collapse; font-size:0.85rem; min-width:600px;">
        <thead>
          <tr style="background:#F8F8F8; border-bottom:2px solid #E0E0E0;">
            <th style="padding:12px 16px; text-align:left; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px;">ID</th>
            <th style="padding:12px 16px; text-align:left; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px;">Name</th>
            <th style="padding:12px 16px; text-align:left; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px;">Price</th>
            <th style="padding:12px 16px; text-align:left; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px;">Discount</th>
            <th style="padding:12px 16px; text-align:left; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px;">Stock</th>
            <th style="padding:12px 16px; text-align:center; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach((product, i) => { %>
          <tr style="border-bottom:1px solid #F0F0F0; background:<%= i % 2 === 0 ? 'white' : '#FAFAFA' %>;" onmouseover="this.style.background='#FFF3EC'" onmouseout="this.style.background='<%= i % 2 === 0 ? 'white' : '#FAFAFA' %>'">
            <td style="padding:12px 16px; color:#9E9E9E; font-size:0.78rem;">#<%= product.id %></td>
            <td style="padding:12px 16px; color:#212121; font-weight:600; max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="<%= product.name %>"><%= product.name %></td>
            <td style="padding:12px 16px; color:#F57224; font-weight:700;">৳<%= product.price %></td>
            <td style="padding:12px 16px;">
              <% if (product.is_discount_enabled && product.discounted_price) { %>
                <span style="background:#ECFDF5; color:#059669; font-size:0.72rem; font-weight:700; padding:2px 8px; border-radius:20px; border:1px solid #A7F3D0;">৳<%= product.discounted_price %></span>
              <% } else { %>
                <span style="color:#E0E0E0; font-size:0.78rem;">—</span>
              <% } %>
            </td>
            <td style="padding:12px 16px;">
              <span style="background:<%= product.stock > 10 ? '#ECFDF5' : product.stock > 0 ? '#FFF8E1' : '#FEF2F2' %>; color:<%= product.stock > 10 ? '#059669' : product.stock > 0 ? '#F59E0B' : '#DC2626' %>; font-size:0.75rem; font-weight:700; padding:2px 8px; border-radius:20px;"><%= product.stock %></span>
            </td>
            <td style="padding:12px 16px; text-align:center;">
              <div style="display:flex; gap:7px; justify-content:center; flex-wrap:wrap;">
                <a href="/dashboard/products-edit/<%= product.id %>"
                  style="background:#1A2A4A; color:white; padding:6px 14px; border-radius:5px; font-size:0.75rem; font-weight:600; text-decoration:none; display:flex; align-items:center; gap:5px; white-space:nowrap;"
                  onmouseover="this.style.background='#F57224'" onmouseout="this.style.background='#1A2A4A'">
                  <i class="fas fa-edit"></i> Edit
                </a>
                <form action="/dashboard/products-delete/<%= product.id %>" method="POST" onsubmit="return confirm('Delete this product?')">
                  <button style="background:#FEF2F2; color:#DC2626; border:1px solid #FCA5A5; padding:6px 14px; border-radius:5px; font-size:0.75rem; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:5px; white-space:nowrap;"
                    onmouseover="this.style.background='#DC2626'; this.style.color='white'" onmouseout="this.style.background='#FEF2F2'; this.style.color='#DC2626'">
                    <i class="fas fa-trash"></i> Delete
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
