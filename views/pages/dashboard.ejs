<style>
.db-stat{background:#fff;border-radius:10px;padding:22px;border:1px solid #EBEBEB;box-shadow:0 2px 8px rgba(0,0,0,0.05);border-left:4px solid #F57224;transition:all 0.2s;}
.db-stat:hover{box-shadow:0 6px 20px rgba(0,0,0,0.1);transform:translateY(-2px);}
.db-stat-num{font-size:2rem;font-weight:800;color:#212121;font-family:'Inter',sans-serif;line-height:1.1;}
.db-stat-label{font-size:0.75rem;font-weight:600;color:#9E9E9E;text-transform:uppercase;letter-spacing:0.5px;margin-top:4px;}
.db-stat-icon{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;}
.db-quick{background:#fff;border-radius:10px;padding:18px;border:1px solid #EBEBEB;text-decoration:none;display:flex;align-items:center;gap:12px;transition:all 0.18s;}
.db-quick:hover{box-shadow:0 4px 16px rgba(0,0,0,0.1);transform:translateY(-2px);}
.db-quick-ico{width:40px;height:40px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.db-quick-label{font-size:0.88rem;font-weight:600;color:#212121;font-family:'Inter',sans-serif;}
</style>

<div>
  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:16px;margin-bottom:24px;">
    <div class="db-stat">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
        <div class="db-stat-icon" style="background:#FFF3EC;"><i class="fas fa-shopping-bag" style="color:#F57224;"></i></div>
      </div>
      <div class="db-stat-num"><%= typeof totalOrders !== 'undefined' ? totalOrders : 0 %></div>
      <div class="db-stat-label">মোট অর্ডার</div>
    </div>
    <div class="db-stat" style="border-left-color:#00A650;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
        <div class="db-stat-icon" style="background:#ECFDF5;"><i class="fas fa-boxes" style="color:#00A650;"></i></div>
      </div>
      <div class="db-stat-num"><%= typeof totalProducts !== 'undefined' ? totalProducts : 0 %></div>
      <div class="db-stat-label">মোট পণ্য</div>
    </div>
    <div class="db-stat" style="border-left-color:#7C3AED;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
        <div class="db-stat-icon" style="background:#EDE9FE;"><i class="fas fa-taka-sign" style="color:#7C3AED;"></i></div>
      </div>
      <div class="db-stat-num" style="font-size:1.5rem;">৳<%= typeof totalRevenue !== 'undefined' ? parseFloat(totalRevenue).toLocaleString('en-BD') : '0' %></div>
      <div class="db-stat-label">মোট রেভিনিউ</div>
    </div>
  </div>

  <!-- Welcome banner -->
  <div style="background:linear-gradient(135deg,#1A2A4A,#243B6A);border-radius:12px;padding:24px 28px;color:#fff;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:20px;">
    <div>
      <h2 style="margin:0 0 6px;font-size:1.1rem;font-weight:700;font-family:'Inter',sans-serif;">Dashboard-এ স্বাগতম 👋</h2>
      <p style="margin:0;color:rgba(255,255,255,0.65);font-size:0.82rem;font-family:'Noto Sans Bengali',sans-serif;">আপনার স্টোর পরিচালনা করুন</p>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap;">
      <a href="/dashboard/products-add" style="background:#F57224;color:#fff;padding:9px 18px;border-radius:6px;font-size:0.84rem;font-weight:600;text-decoration:none;display:flex;align-items:center;gap:6px;" onmouseover="this.style.background='#D4601A'" onmouseout="this.style.background='#F57224'">
        <i class="fas fa-plus"></i> পণ্য যোগ
      </a>
      <a href="/dashboard/orders" style="background:rgba(255,255,255,0.12);color:#fff;padding:9px 18px;border-radius:6px;font-size:0.84rem;font-weight:600;text-decoration:none;display:flex;align-items:center;gap:6px;border:1px solid rgba(255,255,255,0.2);" onmouseover="this.style.background='rgba(255,255,255,0.22)'" onmouseout="this.style.background='rgba(255,255,255,0.12)'">
        <i class="fas fa-list-alt"></i> অর্ডার
      </a>
    </div>
  </div>

  <!-- Quick links -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:14px;">
    <a href="/dashboard/products-manage" class="db-quick">
      <div class="db-quick-ico" style="background:#FFF3EC;"><i class="fas fa-cog" style="color:#F57224;"></i></div>
      <span class="db-quick-label">পণ্য ম্যানেজ</span>
    </a>
    <a href="/dashboard/orders" class="db-quick">
      <div class="db-quick-ico" style="background:#FFF3EC;"><i class="fas fa-list-alt" style="color:#F57224;"></i></div>
      <span class="db-quick-label">সকল অর্ডার</span>
    </a>
    <a href="/dashboard/reviews" class="db-quick">
      <div class="db-quick-ico" style="background:#FFF8E1;"><i class="fas fa-star" style="color:#F59E0B;"></i></div>
      <span class="db-quick-label">রিভিউ</span>
    </a>
    <a href="/download-excel" class="db-quick">
      <div class="db-quick-ico" style="background:#ECFDF5;"><i class="fas fa-file-excel" style="color:#00A650;"></i></div>
      <span class="db-quick-label">Excel Export</span>
    </a>
    <a href="/" target="_blank" class="db-quick">
      <div class="db-quick-ico" style="background:#EFF6FF;"><i class="fas fa-store" style="color:#2563EB;"></i></div>
      <span class="db-quick-label">স্টোর দেখুন</span>
    </a>
  </div>
</div>
