<div style="min-height:80vh; display:flex; align-items:center; justify-content:center; padding:24px 16px; background:#F5F5F5;">
  <div style="background:white; max-width:560px; width:100%; border-radius:14px; box-shadow:0 8px 32px rgba(0,0,0,0.1); overflow:hidden; border:1px solid #E0E0E0;">
    
    <!-- Success Banner -->
    <div style="background:linear-gradient(135deg,#1A2A4A,#243B6A); padding:36px 28px; text-align:center; color:white; position:relative;">
      <div style="width:64px; height:64px; background:#00A650; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; box-shadow:0 4px 16px rgba(0,166,80,0.4);">
        <i class="fas fa-check" style="font-size:1.6rem; color:white;"></i>
      </div>
      <h1 style="margin:0 0 6px; font-size:1.4rem; font-weight:700; font-family:'Noto Sans Bengali',sans-serif;">অর্ডার সফল হয়েছে! 🎉</h1>
      <p style="margin:0; color:rgba(255,255,255,0.75); font-size:0.85rem; font-family:'Noto Sans Bengali',sans-serif;">আপনার অর্ডার #<%= order.orderId %> সফলভাবে গ্রহণ করা হয়েছে</p>
    </div>

    <div style="padding:28px;">
      
      <!-- Customer Details -->
      <div style="background:#F9F9F9; border-radius:8px; padding:18px; margin-bottom:16px; border:1px solid #F0F0F0;">
        <h3 style="margin:0 0 12px; font-size:0.88rem; font-weight:700; color:#212121; display:flex; align-items:center; gap:7px; font-family:'Inter',sans-serif;">
          <i class="fas fa-user" style="color:#F57224;"></i> কাস্টমার তথ্য
        </h3>
        <div style="display:flex; flex-direction:column; gap:6px;">
          <div style="display:flex; justify-content:space-between; font-size:0.82rem;">
            <span style="color:#9E9E9E; font-family:'Noto Sans Bengali',sans-serif;">নাম</span>
            <span style="color:#212121; font-weight:600; font-family:'Noto Sans Bengali',sans-serif;"><%= order.first_name %> <%= order.last_name || '' %></span>
          </div>
          <% if (order.phone) { %>
          <div style="display:flex; justify-content:space-between; font-size:0.82rem;">
            <span style="color:#9E9E9E; font-family:'Noto Sans Bengali',sans-serif;">ফোন</span>
            <span style="color:#212121; font-weight:600;"><%= order.phone %></span>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Shipping Address -->
      <div style="background:#F9F9F9; border-radius:8px; padding:18px; margin-bottom:16px; border:1px solid #F0F0F0;">
        <h3 style="margin:0 0 12px; font-size:0.88rem; font-weight:700; color:#212121; display:flex; align-items:center; gap:7px; font-family:'Inter',sans-serif;">
          <i class="fas fa-map-marker-alt" style="color:#F57224;"></i> ডেলিভারি ঠিকানা
        </h3>
        <p style="margin:0; font-size:0.85rem; color:#616161; line-height:1.7; font-family:'Noto Sans Bengali',sans-serif;">
          <%= order.street %>, <%= order.city %>, <%= order.district %>
          <% if (order.country) { %>, <%= order.country %><% } %>
        </p>
      </div>

      <!-- Payment -->
      <div style="background:#FFF3EC; border-radius:8px; padding:18px; margin-bottom:20px; border:1px solid #FED7AA;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
          <span style="font-size:0.82rem; color:#9E9E9E; font-family:'Noto Sans Bengali',sans-serif;">পেমেন্ট পদ্ধতি</span>
          <span style="font-size:0.82rem; font-weight:600; color:#212121; font-family:'Noto Sans Bengali',sans-serif;"><%= order.payment_method %></span>
        </div>
        <div style="display:flex; justify-content:space-between; align-items:center; padding-top:8px; border-top:1px dashed #FED7AA;">
          <span style="font-size:1rem; font-weight:700; color:#212121; font-family:'Noto Sans Bengali',sans-serif;">সর্বমোট</span>
          <span style="font-size:1.3rem; font-weight:800; color:#F57224; font-family:'Noto Sans Bengali',sans-serif;">৳<%= order.total %></span>
        </div>
      </div>

      <!-- Note -->
      <div style="background:#ECFDF5; border:1px solid #A7F3D0; border-radius:8px; padding:14px; margin-bottom:20px; display:flex; align-items:flex-start; gap:10px;">
        <i class="fas fa-info-circle" style="color:#059669; font-size:1rem; margin-top:2px; flex-shrink:0;"></i>
        <p style="margin:0; font-size:0.82rem; color:#059669; line-height:1.6; font-family:'Noto Sans Bengali',sans-serif;">
          আমাদের টিম শীঘ্রই আপনার সাথে যোগাযোগ করবে। অর্ডার ট্র্যাক করতে নিচের বোতাম ব্যবহার করুন।
        </p>
      </div>

      <!-- Action Buttons -->
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <a href="/" style="flex:1; min-width:130px; text-align:center; background:#1A2A4A; color:white; padding:12px; border-radius:6px; font-size:0.88rem; font-weight:700; text-decoration:none; transition:background 0.2s; font-family:'Noto Sans Bengali',sans-serif;" onmouseover="this.style.background='#F57224'" onmouseout="this.style.background='#1A2A4A'">
          <i class="fas fa-home" style="margin-right:6px;"></i> হোমে যান
        </a>
        <a href="/orders-tracking" style="flex:1; min-width:130px; text-align:center; background:#F57224; color:white; padding:12px; border-radius:6px; font-size:0.88rem; font-weight:700; text-decoration:none; transition:background 0.2s; font-family:'Noto Sans Bengali',sans-serif;" onmouseover="this.style.background='#D4601A'" onmouseout="this.style.background='#F57224'">
          <i class="fas fa-search" style="margin-right:6px;"></i> অর্ডার ট্র্যাক করুন
        </a>
      </div>
    </div>
  </div>
</div>
