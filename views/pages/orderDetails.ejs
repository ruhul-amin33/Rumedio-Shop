<div style="max-width:800px; margin:0 auto; padding:16px 0;">
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:10px;">
    <h2 style="margin:0; font-size:1.15rem; font-weight:700; color:#212121; font-family:'Inter',sans-serif; display:flex; align-items:center; gap:7px;">
      <i class="fas fa-receipt" style="color:#F57224;"></i> Order #<%= orderId %>
    </h2>
    <a href="/dashboard/orders" style="background:#1A2A4A; color:white; padding:7px 16px; border-radius:6px; font-size:0.82rem; font-weight:600; text-decoration:none; display:flex; align-items:center; gap:6px;" onmouseover="this.style.background='#F57224'" onmouseout="this.style.background='#1A2A4A'">
      <i class="fas fa-arrow-left"></i> Back to Orders
    </a>
  </div>

  <div style="background:white; border-radius:10px; border:1px solid #E0E0E0; box-shadow:0 2px 8px rgba(0,0,0,0.06); overflow:hidden;">
    <table style="width:100%; border-collapse:collapse; font-size:0.85rem;">
      <thead>
        <tr style="background:#F8F8F8; border-bottom:2px solid #E0E0E0;">
          <th style="padding:14px 18px; text-align:left; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px;">পণ্য</th>
          <th style="padding:14px 18px; text-align:center; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px;">পরিমাণ</th>
          <th style="padding:14px 18px; text-align:right; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px;">মূল্য</th>
          <th style="padding:14px 18px; text-align:right; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px;">মোট</th>
        </tr>
      </thead>
      <tbody>
        <% let grandTotal = 0; orderItems.forEach((item, i) => { grandTotal += Number(item.total_price); %>
        <tr style="border-bottom:1px solid #F0F0F0; background:<%= i % 2 === 0 ? 'white' : '#FAFAFA' %>;">
          <td style="padding:14px 18px; color:#212121; font-weight:500; font-family:'Noto Sans Bengali',sans-serif;"><%= item.product_name %></td>
          <td style="padding:14px 18px; color:#616161; text-align:center;"><%= item.quantity %></td>
          <td style="padding:14px 18px; color:#616161; text-align:right;">৳<%= Number(item.price).toFixed(2) %></td>
          <td style="padding:14px 18px; color:#F57224; font-weight:700; text-align:right;">৳<%= Number(item.total_price).toFixed(2) %></td>
        </tr>
        <% }) %>
        <tr style="background:#FFF3EC; border-top:2px solid #F57224;">
          <td colspan="3" style="padding:16px 18px; font-size:0.95rem; font-weight:700; color:#212121; text-align:right; font-family:'Noto Sans Bengali',sans-serif;">Grand Total</td>
          <td style="padding:16px 18px; font-size:1.2rem; font-weight:800; color:#F57224; text-align:right; font-family:'Noto Sans Bengali',sans-serif;">৳<%= grandTotal.toFixed(2) %></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
