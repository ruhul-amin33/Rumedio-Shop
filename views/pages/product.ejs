<script>
/* ── Reviews ── */
const PRODUCT_ID  = '<%= product.id %>';
const PER_PAGE    = 3;
let allReviews    = [];
let currentPage   = 0;

async function loadReviews() {
  try {
    const r = await fetch('/reviews/' + PRODUCT_ID);
    allReviews = await r.json();
    renderPage(0);
  } catch {}
}

function renderPage(page) {
  const list  = document.getElementById('rv-list');
  const empty = document.getElementById('rv-empty');
  const count = document.getElementById('rv-count');
  const prev  = document.getElementById('rv-prev');
  const next  = document.getElementById('rv-next');

  currentPage = page;
  const total = allReviews.length;
  const start = page * PER_PAGE;
  const slice = allReviews.slice(start, start + PER_PAGE);

  if (!total) { list.innerHTML=''; empty.style.display='block'; return; }
  empty.style.display = 'none';

  count.textContent = `${start+1}–${Math.min(start+PER_PAGE,total)} / ${total}টি রিভিউ`;
  prev.disabled = page === 0;
  next.disabled = start + PER_PAGE >= total;

  list.innerHTML = slice.map(r => {
    const stars = Array.from({length:5}, (_,i) =>
      `<i class="${i < r.rating ? 'fas' : 'far'} fa-star ${i < r.rating ? '' : 'empty'}"></i>`).join('');
    const initials = r.reviewer_name.charAt(0).toUpperCase();
    const date = new Date(r.created_at).toLocaleDateString('bn-BD');
    const rvImg = r.image_name ? (/^https?:\/\//.test(r.image_name) ? r.image_name : '/images/' + r.image_name) : '';
    return `
      <div class="rv-card">
        <div class="rv-stars">${stars}</div>
        ${rvImg ? `<img src="${rvImg}" class="rv-img" onclick="openLightbox('${rvImg}')" loading="lazy">` : ''}
        ${r.comment ? `<p class="rv-text">${r.comment}</p>` : ''}
        <div class="rv-author">
          <div class="rv-avatar">${initials}</div>
          <div>
            <p class="rv-name">${r.reviewer_name}</p>
            <p class="rv-date">${date}</p>
          </div>
        </div>
      </div>`;
  }).join('');
}

document.getElementById('rv-prev').addEventListener('click', () => renderPage(currentPage - 1));
document.getElementById('rv-next').addEventListener('click', () => renderPage(currentPage + 1));

/* ── Star input ── */
let selectedRating = 5;
const starIcons = document.querySelectorAll('#starInput i');
function setStars(val) {
  selectedRating = val;
  document.getElementById('ratingVal').value = val;
  starIcons.forEach((s, i) => {
    s.className = i < val ? 'fas fa-star active' : 'far fa-star';
  });
}
setStars(5);
starIcons.forEach(s => {
  s.addEventListener('mouseover', () => starIcons.forEach((x,i) => x.className = i < parseInt(s.dataset.val) ? 'fas fa-star active' : 'far fa-star'));
  s.addEventListener('mouseout',  () => setStars(selectedRating));
  s.addEventListener('click',     () => setStars(parseInt(s.dataset.val)));
});

/* ── Image preview ── */
document.getElementById('reviewImg').addEventListener('change', function() {
  const preview = document.getElementById('imgPreview');
  preview.innerHTML = '';
  if (this.files[0]) {
    const reader = new FileReader();
    reader.onload = e => { preview.innerHTML = `<img src="${e.target.result}">`; };
    reader.readAsDataURL(this.files[0]);
  }
});

/* ── Form submit ── */
document.getElementById('reviewForm').addEventListener('submit', async e => {
  e.preventDefault();
  const form = e.target;
  const btn  = form.querySelector('.rv-submit-btn');
  const succ = document.getElementById('rvSuccess');
  const fd   = new FormData(form);

  btn.disabled  = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> জমা হচ্ছে...';

  try {
    const r = await fetch('/reviews/submit', { method:'POST', body:fd });
    const d = await r.json();
    if (d.ok) {
      succ.textContent = '✅ ' + d.message;
      succ.style.display = 'block';
      form.reset(); setStars(5);
      document.getElementById('imgPreview').innerHTML='';
    } else {
      succ.textContent = '❌ ' + d.message;
      succ.style.display = 'block';
      succ.style.background='#FEF2F2'; succ.style.color='#DC2626'; succ.style.border='1px solid #FCA5A5';
    }
  } catch { succ.textContent='❌ সমস্যা হয়েছে।'; succ.style.display='block'; }

  btn.disabled  = false;
  btn.innerHTML = '<i class="fas fa-paper-plane" style="margin-right:6px;"></i>রিভিউ জমা দিন';
  setTimeout(() => succ.style.display='none', 5000);
});

/* ── Lightbox ── */
function openLightbox(src) {
  document.getElementById('lbImg').src = src;
  document.getElementById('rvLightbox').classList.add('open');
}
function closeLightbox() { document.getElementById('rvLightbox').classList.remove('open'); }
document.getElementById('rvLightbox').addEventListener('click', e => { if(e.target === e.currentTarget) closeLightbox(); });

loadReviews();
</script>
