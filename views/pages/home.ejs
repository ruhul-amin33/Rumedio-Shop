<style>
/* ── Page-level styles ── */
.hero-wrap{background:linear-gradient(135deg,#0F1E38 0%,#1A2A4A 45%,#1E3560 100%);padding:56px 16px 64px;color:#fff;position:relative;overflow:hidden;}
.hero-wrap::before{content:'';position:absolute;inset:0;background-image:radial-gradient(circle at 20% 50%,rgba(245,114,36,0.08) 0%,transparent 60%),radial-gradient(circle at 80% 20%,rgba(255,255,255,0.03) 0%,transparent 50%);pointer-events:none;}
.hero-inner{max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;gap:40px;position:relative;z-index:1;}
.hero-text{flex:1;min-width:260px;}
.hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(245,114,36,0.15);border:1px solid rgba(245,114,36,0.4);color:#F57224;font-size:0.72rem;font-weight:700;padding:5px 14px;border-radius:20px;text-transform:uppercase;letter-spacing:0.6px;margin-bottom:18px;}
.hero-h1{font-size:clamp(1.4rem,3.5vw,2.3rem);font-weight:800;line-height:1.28;margin:0 0 20px;font-family:'Noto Sans Bengali',sans-serif;}
.hero-h1 span{color:#F57224;}
.hero-features{display:flex;flex-direction:column;gap:9px;margin-bottom:28px;}
.hero-feature{display:flex;align-items:center;gap:10px;font-size:0.88rem;color:rgba(255,255,255,0.88);}
.hero-feature i{color:#F57224;font-size:0.8rem;flex-shrink:0;}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;}
.btn-hero-primary{background:#F57224;color:#fff;padding:13px 28px;border-radius:6px;font-weight:700;font-size:0.93rem;text-decoration:none;display:inline-flex;align-items:center;gap:8px;box-shadow:0 6px 20px rgba(245,114,36,0.35);transition:all 0.2s;border:none;cursor:pointer;}
.btn-hero-primary:hover{background:#D4601A;transform:translateY(-2px);box-shadow:0 10px 28px rgba(245,114,36,0.45);}
.btn-hero-ghost{background:rgba(255,255,255,0.08);color:#fff;padding:13px 24px;border-radius:6px;font-weight:600;font-size:0.9rem;text-decoration:none;display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,0.2);transition:all 0.2s;backdrop-filter:blur(4px);}
.btn-hero-ghost:hover{background:rgba(255,255,255,0.16);border-color:rgba(255,255,255,0.35);}
.hero-img-wrap{flex-shrink:0;display:flex;justify-content:center;position:relative;}
.hero-img-glow{position:absolute;inset:-20px;background:radial-gradient(circle,rgba(245,114,36,0.25) 0%,transparent 70%);border-radius:50%;filter:blur(20px);}
.hero-img{width:clamp(200px,32vw,320px);border-radius:20px;box-shadow:0 24px 64px rgba(0,0,0,0.45);position:relative;z-index:1;object-fit:cover;aspect-ratio:1;}

/* Trust bar */
.trust-bar{background:#fff;border-bottom:1px solid #EBEBEB;padding:16px 0;}
.trust-inner{max-width:1100px;margin:0 auto;padding:0 16px;display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}
.trust-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;transition:background 0.15s;}
.trust-item:hover{background:#FFF3EC;}
.trust-ico{width:40px;height:40px;border-radius:10px;background:#FFF3EC;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.trust-ico i{color:#F57224;font-size:1.1rem;}
.trust-label{font-size:0.8rem;font-weight:700;color:#212121;margin:0;}
.trust-sub{font-size:0.72rem;color:#9E9E9E;margin:0;}

/* Stats counter */
.stats-section{background:#1A2A4A;padding:36px 16px;}
.stats-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
.stat-card{text-align:center;padding:20px 12px;}
.stat-num{font-size:2rem;font-weight:800;color:#F57224;font-family:'Inter',sans-serif;line-height:1;}
.stat-label{font-size:0.78rem;color:rgba(255,255,255,0.65);margin-top:6px;font-family:'Noto Sans Bengali',sans-serif;}

/* Section header */
.sec-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;padding-bottom:14px;border-bottom:2px solid #F57224;}
.sec-title{margin:0;font-size:1.15rem;font-weight:700;color:#212121;display:flex;align-items:center;gap:9px;font-family:'Inter',sans-serif;}
.sec-title-bar{display:inline-block;width:4px;height:20px;background:#F57224;border-radius:2px;flex-shrink:0;}
.sec-link{background:#F57224;color:#fff;padding:7px 16px;border-radius:5px;font-size:0.8rem;font-weight:600;text-decoration:none;transition:background 0.15s;white-space:nowrap;}
.sec-link:hover{background:#D4601A;}

/* Categories */
.cat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:12px;}
.cat-card{background:#fff;border-radius:10px;border:1.5px solid #E0E0E0;padding:18px 12px;text-align:center;text-decoration:none;transition:all 0.2s;cursor:pointer;}
.cat-card:hover{border-color:#F57224;background:#FFF3EC;transform:translateY(-3px);box-shadow:0 6px 18px rgba(245,114,36,0.12);}
.cat-ico{width:44px;height:44px;border-radius:12px;background:#FFF3EC;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;font-size:1.2rem;}
.cat-name{font-size:0.82rem;font-weight:600;color:#212121;font-family:'Noto Sans Bengali',sans-serif;}

/* Review cards */
.review-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:18px;}
.review-card{background:#fff;border-radius:12px;padding:24px;border:1px solid #EBEBEB;box-shadow:0 2px 12px rgba(0,0,0,0.05);transition:all 0.22s;position:relative;}
.review-card::before{content:'❝';position:absolute;top:16px;right:20px;font-size:2.5rem;color:#F5F5F5;font-family:serif;line-height:1;}
.review-card:hover{box-shadow:0 10px 30px rgba(0,0,0,0.1);transform:translateY(-3px);}
.review-stars{display:flex;gap:2px;margin-bottom:12px;}
.review-stars i{color:#FFC107;font-size:0.82rem;}
.review-text{font-size:0.84rem;line-height:1.75;color:#616161;margin:0 0 18px;font-family:'Noto Sans Bengali',sans-serif;}
.review-author{display:flex;align-items:center;gap:10px;}
.review-avatar{width:38px;height:38px;border-radius:50%;background:#FFF3EC;display:flex;align-items:center;justify-content:center;color:#F57224;font-size:0.9rem;flex-shrink:0;font-weight:700;}
.review-name{font-size:0.83rem;font-weight:700;color:#212121;margin:0;font-family:'Noto Sans Bengali',sans-serif;}
.review-loc{font-size:0.73rem;color:#9E9E9E;margin:0;}

/* Why section */
.why-section{background:#fff;padding:72px 16px;}
.why-inner{max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;gap:48px;}
.why-video{flex:1;min-width:260px;position:relative;}
.why-video video{width:100%;border-radius:14px;box-shadow:0 12px 40px rgba(0,0,0,0.14);display:block;}
.why-content{flex:1;min-width:260px;}
.why-tag{background:#FFF3EC;color:#F57224;font-size:0.72rem;font-weight:700;padding:4px 12px;border-radius:20px;display:inline-block;margin-bottom:14px;}
.why-h2{font-size:1.6rem;font-weight:700;color:#1A2A4A;margin:0 0 16px;line-height:1.35;font-family:'Noto Sans Bengali',sans-serif;}
.why-p{color:#616161;font-size:0.88rem;line-height:1.8;margin:0 0 14px;font-family:'Noto Sans Bengali',sans-serif;}
.why-list{display:flex;flex-direction:column;gap:10px;margin:0 0 24px;}
.why-item{display:flex;align-items:flex-start;gap:10px;}
.why-item-dot{width:22px;height:22px;border-radius:50%;background:#F57224;color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.7rem;flex-shrink:0;margin-top:1px;}
.why-item-text{font-size:0.86rem;color:#444;line-height:1.55;font-family:'Noto Sans Bengali',sans-serif;}

/* Newsletter */
.newsletter{background:linear-gradient(135deg,#0F1E38 0%,#1A2A4A 50%,#1E3560 100%);padding:72px 16px;text-align:center;position:relative;overflow:hidden;}
.newsletter::after{content:'';position:absolute;right:-100px;top:-100px;width:400px;height:400px;background:radial-gradient(circle,rgba(245,114,36,0.08),transparent 70%);pointer-events:none;}
.nl-icon{width:60px;height:60px;background:rgba(245,114,36,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 18px;border:1px solid rgba(245,114,36,0.3);}
.nl-icon i{color:#F57224;font-size:1.4rem;}
.nl-h2{color:#fff;font-size:1.6rem;font-weight:700;margin:0 0 10px;font-family:'Noto Sans Bengali',sans-serif;}
.nl-p{color:rgba(255,255,255,0.65);font-size:0.88rem;margin:0 0 28px;font-family:'Noto Sans Bengali',sans-serif;max-width:480px;margin-left:auto;margin-right:auto;}
.nl-form{display:flex;max-width:460px;margin:0 auto;border-radius:6px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,0.3);}
.nl-input{flex:1;padding:14px 18px;border:none;font-size:0.88rem;outline:none;color:#212121;background:#fff;}
.nl-btn{background:#F57224;color:#fff;border:none;padding:14px 24px;font-weight:700;font-size:0.88rem;cursor:pointer;transition:background 0.2s;white-space:nowrap;}
.nl-btn:hover{background:#D4601A;}

/* Animations */
@keyframes fadeInUp{from{opacity:0;transform:translateY(28px);}to{opacity:1;transform:translateY(0);}}
@keyframes countUp{from{opacity:0;}to{opacity:1;}}
.anim-fade{opacity:0;transform:translateY(28px);transition:opacity 0.55s ease,transform 0.55s ease;}
.anim-fade.visible{opacity:1;transform:translateY(0);}

/* Responsive */
@media(max-width:900px){
  .trust-inner{grid-template-columns:repeat(2,1fr);}
  .stats-inner{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:540px){
  .trust-inner{grid-template-columns:repeat(2,1fr);}
  .stats-inner{grid-template-columns:repeat(2,1fr);}
  .hero-img{display:none;}
  .nl-form{flex-direction:column;border-radius:6px;}
  .nl-input{border-radius:6px 6px 0 0;}
  .nl-btn{border-radius:0 0 6px 6px;padding:13px;}
}
</style>

