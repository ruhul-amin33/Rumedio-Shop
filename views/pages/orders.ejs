<div style="padding:8px 0;">
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:12px;">
    <h1 style="margin:0; font-size:1.25rem; font-weight:700; color:#212121; font-family:'Inter',sans-serif; display:flex; align-items:center; gap:8px;">
      <i class="fas fa-list-alt" style="color:#F57224;"></i> Orders
      <span style="background:#FFF3EC; color:#F57224; font-size:0.75rem; font-weight:700; padding:2px 10px; border-radius:20px; border:1px solid #FED7AA;"><%= orders.length %></span>
    </h1>
    <a href="/download-excel" style="background:#00A650; color:white; padding:8px 18px; border-radius:6px; font-size:0.82rem; font-weight:600; text-decoration:none; display:flex; align-items:center; gap:6px;" onmouseover="this.style.background='#007A3D'" onmouseout="this.style.background='#00A650'">
      <i class="fas fa-file-excel"></i> Excel Export
    </a>
  </div>

  <% if (orders.length === 0) { %>
    <div style="background:white; border-radius:10px; padding:60px; text-align:center; border:1px solid #E0E0E0; box-shadow:0 2px 8px rgba(0,0,0,0.05);">
      <i class="fas fa-inbox" style="font-size:2.5rem; color:#E0E0E0; margin-bottom:12px; display:block;"></i>
      <p style="color:#9E9E9E; font-size:0.9rem; margin:0;">No orders found.</p>
    </div>
  <% } else { %>
  <div style="background:white; border-radius:10px; border:1px solid #E0E0E0; box-shadow:0 2px 8px rgba(0,0,0,0.06); overflow:hidden;">
    <div style="overflow-x:auto;">
      <table style="width:100%; border-collapse:collapse; min-width:900px; font-size:0.82rem;">
        <thead>
          <tr style="background:#F8F8F8; border-bottom:2px solid #E0E0E0;">
            <th style="padding:12px 14px; text-align:left; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px; white-space:nowrap;">ID</th>
            <th style="padding:12px 14px; text-align:left; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px; white-space:nowrap;">Customer</th>
            <th style="padding:12px 14px; text-align:left; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px; white-space:nowrap;">Phone</th>
            <th style="padding:12px 14px; text-align:left; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px; white-space:nowrap;">Total</th>
            <th style="padding:12px 14px; text-align:left; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px; white-space:nowrap;">Address</th>
            <th style="padding:12px 14px; text-align:left; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px; white-space:nowrap;">Area</th>
            <th style="padding:12px 14px; text-align:left; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px; white-space:nowrap;">Date</th>
            <th style="padding:12px 14px; text-align:left; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px; white-space:nowrap;">Status</th>
            <th style="padding:12px 14px; text-align:center; font-weight:700; color:#9E9E9E; text-transform:uppercase; font-size:0.72rem; letter-spacing:0.5px; white-space:nowrap;">Action</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach((order, idx) => { %>
          <%
            const statusColors = {
              pending:    { bg:'#FFF8E1', color:'#F59E0B', border:'#FCD34D' },
              processing: { bg:'#EFF6FF', color:'#2563EB', border:'#93C5FD' },
              shipped:    { bg:'#EDE9FE', color:'#7C3AED', border:'#C4B5FD' },
              delivered:  { bg:'#ECFDF5', color:'#059669', border:'#6EE7B7' },
              cancelled:  { bg:'#FEF2F2', color:'#DC2626', border:'#FCA5A5' },
              returned:   { bg:'#F5F5F5', color:'#616161', border:'#E0E0E0' }
            };
            const sc = statusColors[order.order_status] || { bg:'#F5F5F5', color:'#616161', border:'#E0E0E0' };
          %>
          <tr style="border-bottom:1px solid #F0F0F0; background:<%= idx % 2 === 0 ? 'white' : '#FAFAFA' %>;" onmouseover="this.style.background='#FFF3EC'" onmouseout="this.style.background='<%= idx % 2 === 0 ? 'white' : '#FAFAFA' %>'">
            <td style="padding:12px 14px; font-weight:700; color:#F57224;">#<%= order.id %></td>
            <td style="padding:12px 14px; color:#212121; font-weight:500;"><%= order.username || order.first_name || '—' %></td>
            <td style="padding:12px 14px; color:#616161;"><%= order.phone || '—' %></td>
            <td style="padding:12px 14px; font-weight:700; color:#212121;">৳<%= order.total %></td>
            <td style="padding:12px 14px; color:#616161; max-width:180px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="<%= order.street %>, <%= order.city %>, <%= order.district %>">
              <%= order.street || '—' %><% if(order.city){ %>, <%= order.city %><% } %>
            </td>
            <td style="padding:12px 14px;">
              <span style="background:<%= order.delivery_area === 'dhaka' ? '#EFF6FF' : '#F5F0FF' %>; color:<%= order.delivery_area === 'dhaka' ? '#2563EB' : '#7C3AED' %>; font-size:0.72rem; font-weight:700; padding:2px 8px; border-radius:20px; white-space:nowrap;">
                <%= order.delivery_area === 'dhaka' ? '🏙️ ঢাকা' : '🗺️ বাইরে' %>
              </span>
            </td>
            <td style="padding:12px 14px; color:#9E9E9E; white-space:nowrap; font-size:0.78rem;"><%= new Date(order.created_at).toLocaleString("en-BD", { timeZone: "Asia/Dhaka", dateStyle: "short", timeStyle: "short" }) %></td>
            <td style="padding:12px 14px;">
              <form action="/dashboard/update-order-status/<%= order.id %>" method="POST" style="display:flex; flex-direction:column; gap:5px;">
                <select name="order_status"
                  style="border:1.5px solid #E0E0E0; border-radius:5px; padding:5px 8px; font-size:0.78rem; outline:none; color:#212121; cursor:pointer;"
                  onchange="this.form.submit()"
                  onfocus="this.style.borderColor='#F57224'" onblur="this.style.borderColor='#E0E0E0'">
                  <option value="pending" <%= order.order_status==='pending' ? 'selected':'' %>>Pending</option>
                  <option value="processing" <%= order.order_status==='processing' ? 'selected':'' %>>Processing</option>
                  <option value="shipped" <%= order.order_status==='shipped' ? 'selected':'' %>>Shipped</option>
                  <option value="delivered" <%= order.order_status==='delivered' ? 'selected':'' %>>Delivered</option>
                  <option value="cancelled" <%= order.order_status==='cancelled' ? 'selected':'' %>>Cancelled</option>
                  <option value="returned" <%= order.order_status==='returned' ? 'selected':'' %>>Returned</option>
                </select>
              </form>
            </td>
            <td style="padding:12px 14px; text-align:center;">
              <a href="/dashboard/order-details/<%= order.id %>"
                style="background:#1A2A4A; color:white; padding:6px 14px; border-radius:5px; font-size:0.75rem; font-weight:600; text-decoration:none; white-space:nowrap; transition:background 0.15s;"
                onmouseover="this.style.background='#F57224'" onmouseout="this.style.background='#1A2A4A'">
                Details
              </a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>
</div>
