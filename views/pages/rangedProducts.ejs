<body class="bg-gray-100">

<div class="max-w-7xl mx-auto px-6 py-10 grid grid-cols-1 md:grid-cols-4 gap-8">

  <!-- Sidebar -->
  <aside class="space-y-8">
    <!-- Filter by Price -->
    <div class="bg-white p-6 rounded shadow-md">
      <div class="flex justify-between items-center mb-3">
        <label class="font-bold">Price</label>
      </div>

      <form action="/products/all" method="POST">
        <div class="flex justify-between mb-4">
          <input type="number" name="min" id="minPrice" value="<%= minPrice %>" class="w-24 p-1 border rounded text-center">
          <input type="number" name="max" id="maxPrice" value="<%= maxPrice %>" class="w-24 p-1 border rounded text-center">
        </div>

        <div class="relative h-10 mb-4">
          <div id="sliderTrack" class="absolute top-1/2 w-full h-1.5 rounded bg-gray-300 -translate-y-1/2 z-0"></div>
          <input type="range" id="rangeMin" min="0" max="1800" value="0" step="1"
            class="absolute top-1/2 w-full -translate-y-1/2 appearance-none h-2 bg-transparent pointer-events-none z-10">
          <input type="range" id="rangeMax" min="0" max="1800" value="1800" step="1"
            class="absolute top-1/2 w-full -translate-y-1/2 appearance-none h-2 bg-transparent pointer-events-none z-10">
        </div>

        <button type="submit" class="w-full bg-red-500 text-white py-2 rounded hover:bg-red-600 transition">
          APPLY
        </button>

        <style>
          input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 1.5rem;
            height: 1.5rem;
            border-radius: 9999px;
            background-color: #3b82f6;
            cursor: pointer;
            pointer-events: auto;
          }
          input[type=range]::-moz-range-thumb {
            width: 1.5rem;
            height: 1.5rem;
            border-radius: 9999px;
            background-color: #3b82f6;
            cursor: pointer;
            pointer-events: auto;
          }
        </style>
      </form>
    </div>

    <!-- Categories -->
    <div>
      <h2 class="text-lg font-bold mb-3">Categories</h2>
      <ul class="space-y-2 text-gray-700">
        <li><a href="#" class="hover:text-red-500">Mugs (5)</a></li>
        <li><a href="#" class="hover:text-red-500">Tshirts (6)</a></li>
      </ul>
    </div>

  </aside>

  <!-- Products Grid -->
  <main class="md:col-span-3">
    <h1 class="text-3xl font-bold text-red-500 mb-8">Shop</h1>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      <% if (products && products.length > 0) { %>
        <% products.forEach(product => { %>
          <a href="/products/<%= product.id %>">
            <div class="bg-white shadow-md rounded-lg overflow-hidden hover:shadow-lg transition">
              <div class="w-full h-56 flex items-center justify-center bg-gray-100">
                <img src="/images/<%= product.image_name || 'default.jpg' %>" alt="<%= product.name %>" class="h-full w-full object-cover">
              </div>
              <div class="p-4">
                <h3 class="font-semibold text-lg"><%= product.name %></h3>
                <p class="text-gray-700 font-bold mt-2">$<%= product.price %></p>
                <p class="text-yellow-400 text-sm mt-1">★★★★★</p>
              </div>
            </div>
          </a>
        <% }) %>
      <% } else { %>
        <p class="text-center text-gray-500 col-span-full">No products available yet.</p>
      <% } %>
    </div>

    <!-- Pagination -->
    <div class="flex justify-center mt-8 space-x-2">
    <% if (currentPage > 1) { %>
      <form action="/products/all" method="POST" style="display:inline;">
        <input type="hidden" name="page" value="<%= currentPage - 1 %>">
        <input type="hidden" name="min" value="<%= minPrice %>">
        <input type="hidden" name="max" value="<%= maxPrice %>">
        <button type="submit" class="px-4 py-2 bg-red-500 text-white rounded hover:bg-red-600 transition">←</button>
      </form>
    <% } %>

      <% for (let i = 1; i <= totalPages; i++) { %>
        <% if (i === currentPage) { %>
          <span class="px-4 py-2 bg-red-500 text-white rounded"><%= i %></span>
        <% } else { %>
          <form action="/products/all" method="POST" style="display:inline;">
            <input type="hidden" name="page" value="<%= i %>">
            <input type="hidden" name="min" value="<%= minPrice %>">
            <input type="hidden" name="max" value="<%= maxPrice %>">
            <button type="submit" class="px-4 py-2 border rounded hover:bg-gray-100"><%= i %></button>
          </form>
        <% } %>
      <% } %>

    <% if (currentPage < totalPages) { %>
      <form action="/products/all" method="POST" style="display:inline;">
        <input type="hidden" name="page" value="<%= currentPage + 1 %>">
        <input type="hidden" name="min" value="<%= minPrice %>">
        <input type="hidden" name="max" value="<%= maxPrice %>">
        <button type="submit" class="px-4 py-2 bg-red-500 text-white rounded hover:bg-red-600 transition">→</button>
      </form>
    <% } %>
    </div>

  </main>
</div>

<script src="/js/rangedProducts.js"></script>
</body>
