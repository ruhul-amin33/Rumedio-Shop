  <script>
  /* ── Active nav highlight ── */
  (function(){
    const path = window.location.pathname;
    document.querySelectorAll('.desktop-nav a, .mobile-menu a').forEach(link => {
      const href = link.getAttribute('href');
      if (!href) return;
      const isActive = (href === '/' && path === '/') ||
                       (href !== '/' && path.startsWith(href));
      if (isActive) {
        link.style.color = '#F57224';
        link.style.background = '#FFF3EC';
        link.style.borderRadius = '4px';
      }
    });
  })();
  </script>
  <script>
  (function(){
    /* ── Responsive: show mobile search bar & hamburger ── */
    function applyResponsive(){
      const isMobile = window.innerWidth < 1024;
      const desktopSearch = document.getElementById('desktop-search');
      const mobileBar    = document.getElementById('mobile-search-bar');
      if(desktopSearch) desktopSearch.style.display = isMobile ? 'none' : 'block';
      if(mobileBar)     mobileBar.style.display     = isMobile ? 'block' : 'none';
    }
    applyResponsive();
    window.addEventListener('resize', applyResponsive);

    /* ── Hamburger ── */
    const menuBtn    = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    if(menuBtn && mobileMenu){
      menuBtn.addEventListener('click', e => {
        e.stopPropagation();
        const open = mobileMenu.style.display === 'block';
        mobileMenu.style.display = open ? 'none' : 'block';
        menuBtn.querySelector('i').className = open ? 'fas fa-bars' : 'fas fa-times';
      });
      document.addEventListener('click', e => {
        if(!e.target.closest('#menu-btn') && !e.target.closest('#mobile-menu')){
          mobileMenu.style.display = 'none';
          menuBtn.querySelector('i').className = 'fas fa-bars';
        }
      });
    }

    /* ── Search nav helper ── */
    window.doSearchNav = function(inputId){
      const q = document.getElementById(inputId)?.value?.trim();
      if(q) window.location.href = '/search?q=' + encodeURIComponent(q);
    };

    /* ── Language switch (preserves path & other query params) ── */
    window.toggleLang = function(e){
      e.preventDefault();
      const url = new URL(window.location.href);
      const next = url.searchParams.get('lang') === 'en' ? 'bn' : (document.documentElement.lang === 'bn' ? 'en' : 'bn');
      url.searchParams.set('lang', next);
      window.location.href = url.toString();
    };

    /* ── Enter key on search inputs ── */
    document.querySelectorAll('.site-search-input').forEach(inp => {
      inp.addEventListener('keydown', e => {
        if(e.key === 'Enter'){
          e.preventDefault();
          const q = inp.value.trim();
          if(q) window.location.href = '/search?q=' + encodeURIComponent(q);
        }
      });
    });

    /* ── Back to Top ── */
    const btt = document.getElementById('back-to-top');
    window.addEventListener('scroll', () => {
      btt && btt.classList.toggle('visible', window.scrollY > 300);
    });
    btt && btt.addEventListener('click', () => window.scrollTo({top:0,behavior:'smooth'}));

    /* ── Toast helper ── */
    window.showToast = function(msg, duration){
      const t = document.getElementById('toast');
      if(!t) return;
      t.textContent = msg;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), duration || 2500);
    };

    /* ── Floating Cart (bottom-right) ── */
    function updateFloatingCart(){
      try{
        /* Hide on cart/checkout/thank-you pages */
        const path = window.location.pathname;
        const hidePaths = ['/cart', '/checkout', '/thank-you'];
        const shouldHide = hidePaths.some(p => path === p || path.startsWith(p));

        const s     = JSON.parse(localStorage.getItem('cartSummary')) || {};
        const qty   = parseInt(s.totalQuantity) || 0;
        const price = parseFloat(s.totalPrice)  || 0;
        const btn   = document.getElementById('floating-cart-btn');
        const badge = document.getElementById('fc-badge');
        const label = document.getElementById('fc-label');
        if(!btn) return;

        if(qty > 0 && !shouldHide){
          btn.style.display = 'block';
          if(badge) badge.textContent = qty > 9 ? '9+' : qty;
          if(label) label.textContent = qty + ' পণ্য — ৳' + new Intl.NumberFormat('bn-BD').format(price);
        } else {
          btn.style.display = 'none';
        }
      } catch{}
    }
    updateFloatingCart();
    window.addEventListener('storage', updateFloatingCart);
    window.addEventListener('popstate', updateFloatingCart);
    setInterval(updateFloatingCart, 1000);
  })();
  </script>
</body>
</html>
