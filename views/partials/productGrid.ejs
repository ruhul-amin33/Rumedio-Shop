<style>
.pg-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(195px,1fr));gap:16px;}
.pg-card{background:#fff;border-radius:10px;overflow:hidden;border:1.5px solid #EBEBEB;display:flex;flex-direction:column;transition:all 0.22s;position:relative;text-decoration:none;box-shadow:0 1px 6px rgba(0,0,0,0.05);}
.pg-card:hover{box-shadow:0 10px 28px rgba(0,0,0,0.11);transform:translateY(-4px);border-color:#F57224;}
.pg-badge{position:absolute;top:9px;left:9px;background:#E8192C;color:#fff;font-size:0.66rem;font-weight:800;padding:3px 9px;border-radius:4px;z-index:2;letter-spacing:0.3px;}
.pg-img-wrap{aspect-ratio:1;overflow:hidden;background:#F8F8F8;position:relative;}
.pg-img-wrap img{width:100%;height:100%;object-fit:cover;transition:transform 0.4s ease;}
.pg-card:hover .pg-img-wrap img{transform:scale(1.08);}
.pg-body{padding:12px;display:flex;flex-direction:column;flex:1;}
.pg-name{font-size:0.86rem;font-weight:600;color:#212121;line-height:1.35;margin:0 0 8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;font-family:'Noto Sans Bengali',sans-serif;}
.pg-price-orig{font-size:0.74rem;color:#BDBDBD;text-decoration:line-through;margin:0 0 1px;font-family:'Noto Sans Bengali',sans-serif;}
.pg-price{font-size:1.08rem;font-weight:700;color:#F57224;margin:0 0 10px;font-family:'Noto Sans Bengali',sans-serif;}
.pg-btn{background:#F57224;color:#fff;border:none;border-radius:5px;padding:9px 12px;font-size:0.81rem;font-weight:600;cursor:pointer;width:100%;margin-top:auto;transition:background 0.18s;font-family:'Noto Sans Bengali',sans-serif;display:flex;align-items:center;justify-content:center;gap:6px;}
.pg-btn:hover{background:#D4601A;}
@media(max-width:480px){.pg-grid{grid-template-columns:repeat(2,1fr);gap:10px;}}
</style>

<div class="pg-grid" id="productGrid">
<% if (products && products.length > 0) { %>
  <% products.forEach(product => {
    let images = [];
    try { images = JSON.parse(product.image_name); } catch(e){ images = ['default.jpg']; }
    const price     = product.price;
    const discounted= product.discounted_price;
    const hasDisc   = product.is_discount_enabled && discounted;
    const savePct   = hasDisc ? Math.round((price - discounted) / price * 100) : 0;
    const showPrice = hasDisc ? discounted : price;
    const firstImg  = images[0] || 'default.jpg';
    const imgSrc    = /^https?:\/\//.test(firstImg) ? firstImg : '/images/' + firstImg;
  %>
  <a href="/products/<%= product.id %>" class="pg-card">
    <% if (hasDisc) { %><div class="pg-badge">−<%= savePct %>%</div><% } %>
    <div class="pg-img-wrap">
      <img src="<%= imgSrc %>" alt="<%= product.name %>" loading="lazy">
    </div>
    <div class="pg-body">
      <h3 class="pg-name"><%= product.name %></h3>
      <% if (hasDisc) { %>
        <p class="pg-price-orig">৳<%= new Intl.NumberFormat('bn-BD').format(price) %></p>
      <% } %>
      <p class="pg-price">৳<%= new Intl.NumberFormat('bn-BD').format(showPrice) %></p>
      <button
        class="pg-btn add-to-cart"
        onclick="event.preventDefault();event.stopPropagation();"
        data-id="<%= product.id %>"
        data-name="<%= product.name %>"
        data-image="<%= imgSrc %>"
        data-price="<%= showPrice %>">
        <i class="fas fa-cart-plus"></i> কার্টে যোগ করুন
      </button>
    </div>
  </a>
  <% }) %>
<% } else { %>
  <div style="grid-column:1/-1;text-align:center;padding:60px 20px;color:#9E9E9E;">
    <i class="fas fa-box-open" style="font-size:2.5rem;color:#E0E0E0;display:block;margin-bottom:12px;"></i>
    <p style="font-size:0.9rem;margin:0;font-family:'Noto Sans Bengali',sans-serif;">কোনো পণ্য পাওয়া যায়নি।</p>
  </div>
<% } %>
</div>
